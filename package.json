{
  "name": "2026-tre-helper",
  "version": "1.3.3",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "dev": "vite",
    "fetch": "npm-run-all -lns fetch:artists fetch:events fetch:sessions",
    "fetch:artists": "node scripts/fetch-artists.mjs",
    "fetch:events": "node scripts/fetch-events.mjs",
    "fetch:sessions": "node scripts/fetch-sessions.mjs",
    "generate-pwa-assets": "pwa-assets-generator --preset minimal-2023 public/logo.jpg",
    "lint": "npm-run-all --aggregate-output -lnp lint:*",
    "lint:eslint": "eslint . --fix --cache",
    "lint:format": "prettier --write --experimental-cli .",
    "lint:sort-package-json": "sort-package-json",
    "preview": "vite preview",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@vueuse/core": "^14.3.0",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.34",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@prettier/plugin-pug": "^3.4.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/language-plugin-pug": "^3.2.9",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "~10.8.0",
    "eslint-plugin-vue-pug": "1.0.0-alpha.5",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "pug": "^3.0.4",
    "sort-package-json": "^3.6.1",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6",
    "workbox-build": "^7.4.1",
    "workbox-window": "^7.4.1"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
